[Unit]
Description=KAWA Workflow Engine Service
After=postgresql@16-main.service
StartLimitIntervalSec=0
[Service]
Type=simple
Restart=always
RestartSec=5
StartLimitIntervalSec=120
StartLimitBurst=10
User=kawa-system
ExecStart=/bin/bash /usr/local/bin/kawa-workflow.sh

[Install]
WantedBy=multi-user.target

# =====================================================================
# Environment of the KAWA server (native mode).
#
# Only bootstrap values live here. The user configuration is in
# kawa.config, and ALL the secrets (credentials, keys, JDBC urls)
# are in kawa.secrets.
#
# Everything else (features, SMTP server, OIDC, workflow engine...) is
# stored as Configuration objects inside KAWA and applied from
# kawa.config by: sudo ./install.sh --mode=configure
#
# /!\ Do not export KAWA_STANDALONE_API_SERVER_CONFIGURATION or
# KAWA_SMTP_CONFIG here: a configuration object provided through the
# environment always overrides the stored one, and the configure step
# would have no effect anymore.
# =====================================================================

set -a
. /etc/kawa/kawa.config
. /etc/kawa/kawa.secrets
set +a

FILE_STORE_DIRECTORY=/var/lib/kawa/files
JDBC_DRIVERS_DIRECTORY=/var/lib/kawa/drivers

# Files and directories
# This directory will contain all the files that users uploaded through
# KAWA (the file store). Make sure the underlying partition has
# sufficient space and that it exists.
export KAWA_FILE_STORE_DIRECTORY=$FILE_STORE_DIRECTORY

# JDBC Drivers Directory
# This directory contains the extra JDBC drivers that you require.
# KAWA will add them to its loaded classes on startup.
# Make sure to put jar files in that directory.
export KAWA_JDBC_CONFIGURATION="{ \"jdbcDriversDirectory\": \"$JDBC_DRIVERS_DIRECTORY\" }"

# The local python script runner (bootstrap configuration)
export KAWA_GLOBAL_PYTHON_RUNNER_CONFIG="{\"tls\": false, \"host\": \"127.0.0.1\",\"name\": \"Global\",\"port\": 8815,\"enabled\": true,\"encryptedPrivateKey\": \"\"}"

# SMTP credentials, from kawa.secrets (optional - only used when
# COMMUNICATION_PROVIDER_TYPE=SMTP). The rest of the SMTP
# configuration (host, port, encryption) is applied by the
# configure step.
export KAWA_SMTP_USERNAME=$SMTP_USERNAME
export KAWA_SMTP_PASSWORD=$SMTP_PASSWORD

# HTTPS: TLS termination on the KAWA server (optional).
# Configured in kawa.config (USE_HTTPS + certificate paths).
export KAWA_HTTPS=$USE_HTTPS
if [ "$USE_HTTPS" = "true" ]; then
    export KAWA_PATH_TO_SERVER_CERTIFICATE=$PATH_TO_SERVER_CERTIFICATE
    export KAWA_PATH_TO_SERVER_PRIVATE_KEY=$PATH_TO_SERVER_PRIVATE_KEY
    export KAWA_USE_SECURE_COOKIES=true
fi

# OIDC client secret, from kawa.secrets (optional - only used when
# USE_OIDC=true). The rest of the OIDC configuration is applied by
# the configure step.
export KAWA_OAUTH2_CLIENT_SECRET=$OIDC_CLIENT_SECRET

# Will contain temporary files for the application
export KAWA_PATH_TO_TMP_FILES=/tmp

# Workflow engine
# The private key is used by KAWA to authenticate to the workflow engine.
# It is generated by install.sh, and the matching public key is given to
# the engine (see kawa-workflow.sh).
# KAWA_SERVER_URL is used to generate links in workflow emails.
export KAWA_PRIVATE_KEY_PATH=/etc/kawa/workflow-private-key.pem
export KAWA_SERVER_URL=$KAWA_EXTERNAL_URL

## Leave those as is
export KAWA_BYPASS_VAULT=true
export KAWA_CLICKHOUSE_ALLOW_LIVE_CONNECT=true
export KAWA_LOAD_FRONTEND_FROM_RESOURCES=true
export _JAVA_OPTIONS=--add-opens=java.base/java.nio=ALL-UNNAMED

# This simple standalone install always uses clickhouse + postgres
export KAWA_WAREHOUSE_TYPE=CLICKHOUSE

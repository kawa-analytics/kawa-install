# =====================================================================
# KAWA main configuration file - shared by both installation modes.
#
# After any change to this file, apply it with (from the package dir):
#   sudo ./install.sh --mode=configure
# then restart the KAWA server:
#   native mode: sudo systemctl restart kawa
#   docker mode: (cd docker && docker compose restart kawa-server)
#
# In native mode, the live copy of this file is /etc/kawa/kawa.config.
# =====================================================================

# ---------------------------------------------------
# VERSIONS
# docker mode uses docker image tags, branch form (eg. 1.35.x).
# native mode uses exact JAR versions (eg. 1.35.1).
# They usually track the same branch but are not necessarily
# identical.
# For upgrades, see the README (section 4).
# ---------------------------------------------------
KAWA_DOCKER_VERSION="1.35.x"
KAWA_JAR_VERSION="1.35.1"

# ---------------------------------------------------
# GENERAL CONFIG
# ---------------------------------------------------
LISTEN_PORT=8080

# The URL where KAWA can be reached from the outside
# (eg. https://kawa.wayne.com). It is used to generate
# links in workflow emails.
KAWA_EXTERNAL_URL="http://localhost:8080"

# ---------------------------------------------------
# FEATURES
# Comma separated list of the features to enable.
# Available features:
#   scripts           Python scripts
#   data-samples      Data samples
#   list-principals   Users can list the other users (eg. when sharing)
#   dashboard-export  Dashboard exports
# ---------------------------------------------------
ENABLED_FEATURES="data-samples,list-principals,scripts,dashboard-export"

# ---------------------------------------------------
# EMAILS
# If you wish KAWA to send emails, use SMTP.
# Otherwise use LOG: emails are only printed in the server logs.
#
# Note: the workflow engine does not need any SMTP configuration,
# all emails are sent by the KAWA server.
# ---------------------------------------------------
COMMUNICATION_PROVIDER_TYPE=LOG

# SMTP CONFIG - Only set those values if you used SMTP above
# (Please do not remove those variables)
# The SMTP credentials are secrets: they live in kawa.secrets.
SMTP_PORT=465
SMTP_HOST="localhost"
SMTP_SSL=true
SMTP_START_TLS=false
SMTP_AUTHENTICATION=true

# ---------------------------------------------------
# PYTHON PACKAGE REGISTRY (optional)
# The script runner downloads python packages (from pypi.org
# by default) to package the dependencies of user scripts.
# To use a private registry or mirror instead (Nexus,
# Artifactory...), set USE_CUSTOM_PYPI=true: the runner will
# then honor the standard pip configuration.
# The index url may contain credentials: it lives in kawa.secrets.
# ---------------------------------------------------
USE_CUSTOM_PYPI=false

# ---------------------------------------------------
# HTTPS
# Set USE_HTTPS=true to terminate TLS on the KAWA server,
# and point the two paths to your certificate and key files.
# native mode: the server reads them from these paths
#              (make them readable by the kawa-system user).
# docker mode: the installer copies them next to the compose file.
# ---------------------------------------------------
USE_HTTPS=false
PATH_TO_SERVER_CERTIFICATE=/etc/kawa/server.crt
PATH_TO_SERVER_PRIVATE_KEY=/etc/kawa/server.key

# ---------------------------------------------------
# OIDC / SSO (optional)
# Works with any OIDC-compliant identity provider (Auth0,
# OKTA, Cognito, Entra ID, Keycloak...). Create a web
# application integration with the authorization code grant
# and refresh tokens. KAWA requests the following scopes:
# openid, profile, email, offline_access.
# Users must have a verified email on the provider.
# The client secret is a secret: it lives in kawa.secrets.
# ---------------------------------------------------
USE_OIDC=false
OIDC_CLIENT_ID=""
# The base URL exposing /.well-known/openid-configuration
# eg. https://your-idp.example.com/oauth2/default
OIDC_ISSUER=""
# The URL users type to reach KAWA. Defaults to KAWA_EXTERNAL_URL.
OIDC_CLIENT_HOST=""

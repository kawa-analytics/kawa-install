# Configuration for the KAWA workflow engine (native mode).
#
# The engine stores its state in the dedicated "workflow" database
# (schema "workflow"), created by install.sh. Tables are created by
# the engine on first start. The JDBC url (a secret) lives in
# kawa.secrets.
#
# No mail configuration is needed here: workflow emails are sent
# through the KAWA server and its SMTP configuration (see kawa.config).

set -a
. /etc/kawa/kawa.secrets
set +a

# Port the workflow engine listens on
export SERVER_PORT=8088
